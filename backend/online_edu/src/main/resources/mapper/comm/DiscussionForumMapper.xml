<?xml version="1.0" encoding="UTF-8" ?>
<!DOCTYPE mapper PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN" "http://mybatis.org/dtd/mybatis-3-mapper.dtd">
<mapper namespace="com.comm.mapper.DiscussionForumMapper">

    <resultMap id="ForumResultMap" type="com.comm.entity.DiscussionForum">
        <id property="forumId" column="forum_id"/>
        <result property="courseId" column="course_id"/>
        <result property="forumName" column="forum_name"/>
        <result property="description" column="description"/>
        <result property="isPublic" column="is_public"/>
        <result property="status" column="status"/>
        <result property="delFlag" column="del_flag"/>
        <result property="createTime" column="create_time"/>
        <result property="updateTime" column="update_time"/>
        <result property="remark" column="remark"/>
        <result property="courseName" column="course_name"/>
    </resultMap>
    
    <select id="selectForumList" resultMap="ForumResultMap">
        SELECT
            f.forum_id,
            f.course_id,
            f.forum_name,
            f.description,
            f.is_public,
            f.status,
            f.create_time,
            f.remark,
            c.course_name
        FROM
            comm_discussion_forum f
        LEFT JOIN
            edu_course c ON f.course_id = c.course_id
        <where>
            f.del_flag = 0
            <if test="courseId != null">
                AND f.course_id = #{courseId}
            </if>
            <if test="forumName != null and forumName != ''">
                AND f.forum_name LIKE CONCAT('%', #{forumName}, '%')
            </if>
            <if test="isPublic != null">
                AND f.is_public = #{isPublic}
            </if>
        </where>
        ORDER BY f.create_time DESC
    </select>
    
</mapper> 