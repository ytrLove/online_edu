<?xml version="1.0" encoding="UTF-8" ?>
<!DOCTYPE mapper PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN" "http://mybatis.org/dtd/mybatis-3-mapper.dtd">
<mapper namespace="com.course.mapper.EduChapterMapper">

    <resultMap id="ChapterResultMap" type="com.course.model.entity.EduChapter">
        <id column="chapter_id" property="chapterId"/>
        <result column="course_id" property="courseId"/>
        <result column="title" property="title"/>
        <result column="sort" property="sort"/>
        <result column="status" property="status"/>
        <result column="del_flag" property="delFlag"/>
        <result column="create_time" property="createTime"/>
        <result column="update_time" property="updateTime"/>
        <result column="remark" property="remark"/>
        <result column="course_name" property="courseName"/>
    </resultMap>

    <sql id="selectChapterVo">
        select c.chapter_id, c.course_id, c.title, c.sort, c.status, c.del_flag, c.create_time, c.update_time, c.remark,
               ec.course_name
        from edu_chapter c
        left join edu_course ec on c.course_id = ec.course_id
    </sql>

    <select id="selectChaptersByCourseId" parameterType="Long" resultMap="ChapterResultMap">
        <include refid="selectChapterVo"/>
        where c.course_id = #{courseId} and c.del_flag = 0
        order by c.sort, c.create_time
    </select>

    <select id="selectChapterPage" resultMap="ChapterResultMap">
        <include refid="selectChapterVo"/>
        where c.course_id = #{courseId} and c.del_flag = 0
        order by c.sort, c.create_time
    </select>
</mapper> 