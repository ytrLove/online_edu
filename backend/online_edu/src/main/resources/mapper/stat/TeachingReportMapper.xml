<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE mapper PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN" "http://mybatis.org/dtd/mybatis-3-mapper.dtd">
<mapper namespace="com.stat.mapper.TeachingReportMapper">

    <!-- 通用查询映射结果 -->
    <resultMap id="BaseResultMap" type="com.stat.model.entity.TeachingReport">
        <id column="report_id" property="reportId"/>
        <result column="course_id" property="courseId"/>
        <result column="teacher_id" property="teacherId"/>
        <result column="report_type" property="reportType"/>
        <result column="report_period" property="reportPeriod"/>
        <result column="start_time" property="startTime"/>
        <result column="end_time" property="endTime"/>
        <result column="report_data" property="reportData"/>
        <result column="insights" property="insights"/>
        <result column="improvement_areas" property="improvementAreas"/>
        <result column="generate_time" property="generateTime"/>
    </resultMap>

    <!-- 分页查询教师报告列表 -->
    <select id="selectTeacherReportPage" resultMap="BaseResultMap">
        SELECT *
        FROM stat_teaching_report
        WHERE 1=1
        <if test="teacherId != null">
            AND teacher_id = #{teacherId}
        </if>
        <if test="courseId != null">
            AND course_id = #{courseId}
        </if>
        <if test="startTime != null">
            AND generate_time >= #{startTime}
        </if>
        <if test="endTime != null">
            AND generate_time &lt;= #{endTime}
        </if>
        ORDER BY generate_time DESC
    </select>

    <!-- 分页查询课程报告列表 -->
    <select id="selectCourseReportPage" resultMap="BaseResultMap">
        SELECT *
        FROM stat_teaching_report
        WHERE course_id = #{courseId}
        <if test="startTime != null">
            AND generate_time >= #{startTime}
        </if>
        <if test="endTime != null">
            AND generate_time &lt;= #{endTime}
        </if>
        ORDER BY generate_time DESC
    </select>

</mapper> 