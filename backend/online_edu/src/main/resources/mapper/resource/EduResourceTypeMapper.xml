<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE mapper PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN" "http://mybatis.org/dtd/mybatis-3-mapper.dtd">
<mapper namespace="com.course.mapper.EduResourceTypeMapper">

    <!-- 通用查询结果映射 -->
    <resultMap id="BaseResultMap" type="com.course.model.entity.EduResourceType">
        <id column="type_id" property="typeId" />
        <result column="type_name" property="typeName" />
        <result column="file_extensions" property="fileExtensions" />
        <result column="icon" property="icon" />
        <result column="status" property="status" />
        <result column="create_time" property="createTime" />
        <result column="update_time" property="updateTime" />
        <result column="remark" property="remark" />
    </resultMap>
    
    <!-- 查询所有资源类型列表 -->
    <select id="selectResourceTypeList" resultMap="BaseResultMap">
        SELECT 
            type_id, 
            type_name, 
            file_extensions, 
            icon, 
            status, 
            create_time, 
            update_time, 
            remark
        FROM edu_resource_type
        ORDER BY type_id ASC
    </select>
    
</mapper> 