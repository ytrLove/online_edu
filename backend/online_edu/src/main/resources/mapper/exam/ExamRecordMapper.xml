<?xml version="1.0" encoding="UTF-8" ?>
<!DOCTYPE mapper PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN" "http://mybatis.org/dtd/mybatis-3-mapper.dtd">
<mapper namespace="com.exam.mapper.ExamRecordMapper">

    <resultMap id="RecordResultMap" type="com.exam.model.entity.ExamRecord">
        <id property="recordId" column="record_id"/>
        <result property="examId" column="exam_id"/>
        <result property="studentId" column="student_id"/>
        <result property="totalScore" column="total_score"/>
        <result property="startTime" column="start_time"/>
        <result property="submitTime" column="submit_time"/>
        <result property="status" column="status"/>
        <result property="createTime" column="create_time"/>
        <result property="updateTime" column="update_time"/>
        <result property="examTitle" column="exam_title"/>
        <result property="courseName" column="course_name"/>
        <result property="studentName" column="student_name"/>
        <result property="totalPoints" column="total_points"/>
    </resultMap>

    <sql id="selectRecordVo">
        select r.record_id, r.exam_id, r.student_id, r.total_score, r.start_time, r.submit_time,
               r.status, r.create_time, r.update_time,
               e.title as exam_title, e.total_points, c.course_name, u.username as student_name
        from exam_record r
        left join exam_paper e on r.exam_id = e.exam_id
        left join edu_course c on e.course_id = c.course_id
        left join edu_student s on r.student_id = s.student_id
        left join edu_teacher t on e.teacher_id = t.teacher_id
        left join sys_user u on s.user_id = u.user_id
    </sql>

    <select id="selectRecordPage" resultMap="RecordResultMap">
        <include refid="selectRecordVo"/>
        <where>
            <if test="record != null">
                <if test="record.examId != null">
                    AND r.exam_id = #{record.examId}
                </if>
                <if test="record.studentId != null">
                    AND r.student_id = #{record.studentId}
                </if>
                <if test="record.status != null">
                    AND r.status = #{record.status}
                </if>
            </if>
        </where>
        ORDER BY r.create_time DESC
    </select>

    <select id="selectTeacherRecordPage" resultMap="RecordResultMap">
        <include refid="selectRecordVo"/>
        <where>
            e.teacher_id = #{teacherId}
            <if test="record != null">
                <if test="record.examId != null">
                    AND r.exam_id = #{record.examId}
                </if>
                <if test="record.studentId != null">
                    AND r.student_id = #{record.studentId}
                </if>
                <if test="record.status != null">
                    AND r.status = #{record.status}
                </if>
            </if>
        </where>
        ORDER BY r.create_time DESC
    </select>

    <select id="selectRecordById" resultMap="RecordResultMap">
        <include refid="selectRecordVo"/>
        where r.record_id = #{recordId}
    </select>

    <select id="selectStudentRecordPage" resultMap="RecordResultMap">
        <include refid="selectRecordVo"/>
        <where>
            r.student_id = #{studentId}
            <if test="record != null">
                <if test="record.examId != null">
                    AND r.exam_id = #{record.examId}
                </if>
                <if test="record.status != null">
                    AND r.status = #{record.status}
                </if>
            </if>
        </where>
        ORDER BY r.create_time DESC
    </select>

    <select id="selectStudentRecordByExamId" resultMap="RecordResultMap">
        <include refid="selectRecordVo"/>
        where r.exam_id = #{examId} and r.student_id = #{studentId}
    </select>

    <select id="selectExamStats" resultMap="RecordResultMap">
        <include refid="selectRecordVo"/>
        where r.exam_id = #{examId} and r.status = 'graded'
        ORDER BY r.total_score DESC
    </select>

    <select id="countByExamId" resultType="int">
        select count(*) from exam_record where exam_id = #{examId}
    </select>

</mapper> 